# Copy to ".env" and replace ALL placeholder values. Never commit ".env".

# HTTP port for Express (default 5000 if unset)
PORT=5000

# MongoDB connection string (Atlas or local).
# If the password contains @ # % etc., URL-encode them (e.g. @ -> %40).
MONGO_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_CLUSTER_HOST/YOUR_DB_NAME?retryWrites=true&w=majority

# Secret for signing JWTs (use a long random string in production).
JWT_SECRET=YOUR_LONG_RANDOM_SECRET_STRING

# JWT lifetime (e.g. 12h, 7d, 3600). Optional; defaults to 12h if unset.
JWT_EXPIRES_IN=12h

# Optional. JSON array of login users for /api/v1/auth/login.
# If unset, the app uses built-in demo users from src/config/authUsers.js (not for production).
# Must be ONE line (no line breaks). Use double quotes inside JSON.
# Roles: HQ_ADMIN | PROVINCE_ADMIN | DISTRICT_OFFICER | STATION_OFFICER | DEVICE
# Include ids only where the role needs scope (Mongo ObjectId strings from your DB):
#   PROVINCE_ADMIN  -> provinceId
#   DISTRICT_OFFICER -> districtId
#   STATION_OFFICER  -> stationId (and usually districtId in token if you set it in users)
#   DEVICE          -> tukId
AUTH_USERS=[{"username":"YOUR_HQ_USERNAME","password":"YOUR_HQ_PASSWORD","role":"HQ_ADMIN"},{"username":"YOUR_PROVINCE_USERNAME","password":"YOUR_PROVINCE_PASSWORD","role":"PROVINCE_ADMIN","provinceId":"YOUR_PROVINCE_MONGODB_ID"},{"username":"YOUR_DISTRICT_USERNAME","password":"YOUR_DISTRICT_PASSWORD","role":"DISTRICT_OFFICER","districtId":"YOUR_DISTRICT_MONGODB_ID"},{"username":"YOUR_STATION_USERNAME","password":"YOUR_STATION_PASSWORD","role":"STATION_OFFICER","districtId":"YOUR_DISTRICT_MONGODB_ID","stationId":"YOUR_STATION_MONGODB_ID"},{"username":"YOUR_DEVICE_USERNAME","password":"YOUR_DEVICE_PASSWORD","role":"DEVICE","tukId":"YOUR_TUK_MONGODB_ID"}]

# Optional. Used by `npm test` if set; otherwise tests use MONGO_URI with database name "webapi_test".
# Example: same host as MONGO_URI but .../webapi_test?...
# TEST_MONGO_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_CLUSTER_HOST/webapi_test?retryWrites=true&w=majority

# Optional. Common in production (not required locally).
# NODE_ENV=development
